generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id        String   @id @default(cuid())
  label     String
  url       String
  thumbnail String?
  subtitle  String?
  parentId  String?
  order     Int      @default(0)
  type      String   @default("link") // link | mega-rjesenja | mega-proizvodi
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  template  String   // rjesenja | proizvodi | reference | dizajn-enterijera | o-nama | kontakt
  content   String   // JSON blob sa blokovima
  metaTitle String?
  metaDesc  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String   // HTML ili Markdown
  category    String   @default("Vodiči") // Vodiči | Analize | Trendovi
  thumbnail   String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimetype  String
  size      Int
  alt       String?
  folder    String?
  createdAt DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model ProductCategory {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  order    Int       @default(0)
  products Product[]
}

model Product {
  id          String          @id @default(cuid())
  title       String
  series      String?
  description String?
  specs       String          @default("[]")
  images      String          @default("[]")
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  order       Int             @default(0)
  subGroup    String?
  subGroupOrder Int           @default(0)
  published   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  rjesenjaItems RjesenjaItem[]
}

model DesignStudio {
  id       String          @id @default(cuid())
  badge    String
  name     String
  tag      String
  order    Int             @default(0)
  projects DesignProject[]
}

model DesignProject {
  id           String        @id @default(cuid())
  studioId     String
  studio       DesignStudio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  caption      String
  overlayLabel String
  image        String
  order        Int           @default(0)
  published    Boolean       @default(true)
  createdAt    DateTime      @default(now())
}

model Realizacija {
  id          String   @id @default(cuid())
  name        String
  country     String
  images      String   @default("[]") // JSON array of image paths
  categories  String   @default("[]") // JSON array: ["supermarketi","police","korpe","horeca"]
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RjesenjaItem {
  id           String  @id @default(cuid())
  rjesenjaSlug String
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order        Int     @default(0)

  @@unique([rjesenjaSlug, productId])
  @@index([rjesenjaSlug])
}
